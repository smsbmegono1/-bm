AddEventHandler('onClientResourceStart', function(resourceName)
    if GetCurrentResourceName() == resourceName then
        Citizen.Wait(1000)
        TriggerEvent('chat:addMessage', { args = { "System", "🚀 เริ่มฟาร์มอัตโนมัติแล้ว!" } })
        print("🚀 เริ่มฟาร์มอัตโนมัติแล้ว! กด F8 เพื่อหยุด")
    end
end)
